# Copy these variable names into Railway's Variables dashboard and fill in real values.
# DO NOT commit actual secrets.

APP_NAME=Resume Analyzer API
APP_VERSION=0.3.0

# Railway provides a PostgreSQL plugin — use its DATABASE_URL variable directly
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Generate a strong random secret: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Set this to your Vercel frontend URL after deploying
ALLOWED_ORIGINS=["https://your-app.vercel.app"]

LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=
